{
  "name": "coresound-desktop",
  "version": "0.1.1",
  "description": "Desktop Bluetooth audio controller",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win"
  },
  "author": "CriticalRange",
  "license": "GPL-3.0-only",
  "dependencies": {
    "dbus-next": "^0.10.2",
    "lucide": "^1.16.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.coresound.desktop",
    "productName": "CoreSound",
    "publish": null,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/rfcomm-helper.py"
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/windows-icons/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/linux-icons",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true
    }
  }
}
