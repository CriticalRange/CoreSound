{
  "name": "coresound-desktop",
  "version": "0.1.6",
  "description": "Desktop Bluetooth audio controller",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:win:store": "electron-builder --win --config.win.target=appx --config.extraMetadata.isStoreBuild=true --config.publish=never"
  },
  "author": "CriticalRange",
  "license": "GPL-3.0-only",
  "dependencies": {
    "dbus-next": "^0.10.2",
    "electron-updater": "^6.8.3",
    "lucide": "^1.16.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.coresound.desktop",
    "productName": "CoreSound",
    "publish": {
      "provider": "github",
      "owner": "CriticalRange",
      "repo": "CoreSound",
      "publishAutoUpdate": false
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/rfcomm-helper.py",
      "src/rfcomm-helper.exe"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/windows-icons/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/linux-icons",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true
    },
    "appx": {
      "displayName": "CoreSound",
      "publisherDisplayName": "CriticalRange",
      "identityName": "PLACEHOLDER.CoreSound",
      "publisher": "CN=PLACEHOLDER",
      "applicationId": "CoreSound",
      "backgroundColor": "#000000",
      "languages": ["en-US"],
      "addAutoLaunchExtension": false
    }
  }
}
